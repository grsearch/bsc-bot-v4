# ============================================================
# Four.meme BSC Sniper Bot v4 — 环境变量
# 复制为 .env 并填入实际值。永远不要提交 .env 到 git！
# ============================================================

# ─── BSC RPC ───
ALCHEMY_WSS=wss://bsc-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_HTTP=https://bsc-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MEV_GUARD_RPC=https://bscrpc.pancakeswap.finance

# ─── 钱包（仅使用专用热钱包！）───
PRIVATE_KEY=your_private_key_here

# ─── API Keys ───
BIRDEYE_API_KEY=your_birdeye_api_key
BSCSCAN_API_KEY=your_bscscan_api_key

# ─── 交易参数 ───
BUY_AMOUNT_BNB=0.2
SLIPPAGE_PERCENT=30
GAS_PRICE_GWEI=5
GAS_LIMIT=500000

# ─── 买入阈值条件 ───
MIN_FDV=30000
MIN_LP=10000
MIN_HOLDERS=20

# ─── Dashboard ───
DASHBOARD_PORT=3000
